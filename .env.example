PORT=5000
CORS_ORIGIN=*
DATABASE_URL=postgresql://user:password@host:5432/database

# Nomba API Configuration (Sandbox)
NOMBA_BASE_URL=https://sandbox.nomba.com
NOMBA_ACCOUNT_ID=
NOMBA_SUB_ACCOUNT_ID=
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_PRIVATE_KEY=
NOMBA_WEBHOOK_SECRET=NombaHackathon2026

# Resend Email Configuration
RESEND_API_KEY=
# Sender address. MUST use a domain verified at https://resend.com/domains
# (e.g. "PayMatch <noreply@yourdomain.com>"). On the free/test tier, sending
# to any address other than the account owner fails without a verified domain.
RESEND_FROM_EMAIL=PayMatch <onboarding@resend.dev>
# On the free/test tier (resend.dev), Resend can only deliver to the account
# owner. When a customer send is rejected, the email is re-routed to this
# address so it is still delivered for testing. Defaults to the Resend owner.
RESEND_TEST_RECIPIENT=eniolabadmus351@gmail.com

# Gemini AI Configuration
GEMINI_API_KEY=

# Payment URL (Frontend)
PAYMENT_URL=https://paymatch-frontend.vercel.app
